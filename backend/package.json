{
  "name": "portfolio_manager",
  "version": "0.0.1",
  "description": "<p align=\"center\">\r   <a href=\"http://nestjs.com/\" target=\"blank\"><img src=\"https://nestjs.com/img/logo-small.svg\" width=\"120\" alt=\"Nest Logo\" /></a>\r </p>",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development dotenv -e .env.development -- nest start --watch",
    "start:e2e": "cross-env NODE_ENV=test PORT=3000 DATABASE_URL=postgresql://portfolio:portfolio_pass@localhost:55432/portfolio_e2e JWT_SECRET=portfolio-manager-e2e-secret JWT_EXPIRATION=1h FRONTEND_URL=http://localhost:3001 CORS_ORIGINS=http://localhost:3001 BACKEND_PUBLIC_URL=http://localhost:3000 EMAIL_TRANSPORT=json \"EMAIL_FROM=Portfolio Manager <noreply@portfolio.test>\" GOOGLE_CLIENT_ID=e2e GOOGLE_CLIENT_SECRET=e2e GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback nest start",
    "start:prod": "cross-env NODE_ENV=production dotenv -e .env.production -- node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "dotenv -e .env.development jest",
    "test:watch": "dotenv -e .env.development jest --watch",
    "test:cov": "dotenv -e .env.development jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test DATABASE_URL=postgresql://portfolio:portfolio_pass@localhost:55432/portfolio_e2e JWT_SECRET=portfolio-manager-e2e-secret FRONTEND_URL=http://localhost:3001 CORS_ORIGINS=http://localhost:3001 BACKEND_PUBLIC_URL=http://localhost:3000 EMAIL_TRANSPORT=json \"EMAIL_FROM=Portfolio Manager <noreply@portfolio.test>\" GOOGLE_CLIENT_ID=e2e GOOGLE_CLIENT_SECRET=e2e GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback jest --config ./test/jest-e2e.json --runInBand",
    "prisma:dev:generate": "dotenv -e .env.development -- prisma generate",
    "prisma:dev:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:dev:studio": "dotenv -e .env.development -- prisma studio",
    "prisma:e2e:migrate": "cross-env DATABASE_URL=postgresql://portfolio:portfolio_pass@localhost:55432/portfolio_e2e prisma migrate deploy",
    "prisma:e2e:seed": "cross-env DATABASE_URL=postgresql://portfolio:portfolio_pass@localhost:55432/portfolio_e2e ts-node prisma/e2e-seed.ts",
    "prisma:prod:generate": "dotenv -e .env.production -- prisma generate",
    "prisma:prod:migrate": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:prod:studio": "dotenv -e .env.production -- prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.13.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.1",
    "hbs": "^4.2.0",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.13.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "keywords": []
}
